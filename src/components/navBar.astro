---
import ThemeToggle from '../components/themeToggle.astro';

const navLinks = [
    { label: 'HOME', href: '#home' },
    { label: 'ABOUT ME', href: '#about' },
    { label: 'SKILLS', href: '#' },
    { label: 'BLOG', href: '#' },
];

const isCurrentPage = (href: string) => {
    if (href.startsWith('#')) return false;
    let pathname = Astro.url.pathname;
    if (pathname.at(0) !== '/') pathname = '/' + pathname;
    if (pathname.at(-1) !== '/') pathname += '/';
    return pathname === href || (href !== '/' && pathname.startsWith(href));
};

---

<div class="site-header">
    <div class="container header-inner">
        <!-- LEFT: Logo + Brand -->
        <div class="brand">
            <a class="brand-name" href="/"><span class="gradient-text">ANDREW</span>.Dev</a>
        </div>

        <!-- RIGHT: Nav + CTA -->
        <div class="nav-wrapper">
            <nav class="main-nav" aria-label="Main navigation">
                <ul class="nav-list" id="navList">
                    {navLinks.map((link) => (
                        <li>
                            <a 
                                href={link.href} 
                                class={isCurrentPage(link.href) ? 'active' : ''}
                                aria-current={isCurrentPage(link.href) ? 'page' : undefined}
                            >
                                {link.label}
                            </a>
                        </li>
                    ))}
                    <!-- Mobile CTA - only shows in dropdown -->
                    <li class="mobile-cta-item">
                        <a href="#" class="btn-cta mobile-cta" id="openTalkMobile">LET'S TALK</a>
                    </li>
                </ul>
            </nav>

            <a href="#" class="btn-cta desktop-cta" id="openTalk">LET'S TALK</a>

            <ThemeToggle />

            <button 
                type="button"
                class="mobile-toggle" 
                id="mobileToggle" 
                aria-label="Toggle navigation menu" 
                aria-expanded="false"
                aria-controls="navList"
            >
                ☰
            </button>
        </div>
    </div>
</div>
<div class="talk-modal" id="talkModal">
    <div class="talk-modal-overlay" id="talkOverlay"></div>
    <div class="talk-modal-content">
        <button type="button" class="career-back" id="closeTalk">⬅ BACK</button>
        <div class="talk-modal-body">
            <h2>Send Me a Message</h2>
            <p>Have any suggestions or need any help? I'd love to hear from you.</p>

            <form class="talk-form" id="talkForm">
                <input type="text" name="name" autocomplete="off" placeholder="Your Name" required>
                <input type="email" name="email" autocomplete="off" placeholder="Your Email" required>
                <textarea name="message" autocomplete="off" rows="5" placeholder="Your Message" required></textarea>
                <button type="submit" class="talk-submit-btn">Submit</button>
            </form>
        </div>
    </div>
</div>
<div class="toast" id="toast"></div>
<style>
    .site-header {
        width: 100%;
        background: var(--bg);
        border-bottom: 1px solid rgba(255, 255, 255, 0.18);
        box-shadow: 0 8px 32px rgba(50, 50, 50, 0.343);
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 9999;
        transition: background 0.3s ease;
    }

    .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 80px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .brand img {
        height: 45px;
        width: auto;
    }

    .brand-name {
        font-weight: 800;
        letter-spacing: 1px;
        font-size: 16px;
        color: var(--text);
        text-decoration: none;
        font-family: var(--font-main);
    }

    .brand-name span {
        background-image: linear-gradient(90deg, var(--gradient-start), var(--gradient-mid), var(--gradient-end));
        background-clip: text;
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
    }

    .nav-wrapper {
        display: flex;
        align-items: center;
        gap: 30px;
    }

    .nav-list {
        display: flex;
        gap: 28px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .nav-list a {
        position: relative;
        display: inline-block;
        align-items: center;
        padding: 12px 6px;
        font-size: 13px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text);
        text-decoration: none;
        transition: color 0.3s ease, transform 0.3s ease;
        font-family: var(--font-main);
    }

    /* Lobster font hover effect */
    .nav-list a:hover,
    .nav-list a.active {
        color: var(--primary);
        transform: translateY(-3px) scale(1.1);
    }

    .nav-list a::after {
        content: '';
        position: absolute;
        bottom: 1px;
        left: 0;
        width: 0;
        height: 2px;
        background: var(--primary);
        transition: width 0.3s ease;
    }

    .nav-list a:hover::after,
    .nav-list a.active::after {
        width: 100%;
    }

    .btn-cta {
        background: var(--primary);
        color: white;
        padding: 10px 22px;
        border-radius: 999px;
        font-family: var(--font-main);
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: opacity 0.3s ease;
        white-space: nowrap;
    }

    .btn-cta:hover {
        opacity: 0.9;
    }

    /* Mobile CTA hidden by default */
    .mobile-cta-item {
        display: none;
    }

    .mobile-cta {
        display: inline-block;
        margin-top: 10px;
    }

    .mobile-toggle {
        display: none;
        color: var(--text);
        background: none;
        border: none;
        font-size: 26px;
        cursor: pointer;
        padding: 4px;
        line-height: 1;
    }

    .talk-modal {
        position: fixed;
        inset: 0;
        display: none;
        z-index: 99999;
    }

    /* BACK BUTTON */
    .career-back {
        background: var(--primary);
        border: none;
        padding: 8px 18px;
        border-radius: 999px;
        font-family: var(--font-text);
        color: var(--text);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        margin-bottom: 30px;
    }

    .talk-modal.active {
        display: block;
    }

    .talk-modal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(10px);
    }

    .talk-modal-content {
        position: relative;
        max-width: 700px;
        width: 90%;
        margin: 80px auto;
        background: var(--bg);
        box-shadow: 0 30px 80px rgba(0, 0, 0, 0.25);
        border-radius: 20px;
        padding: 40px;
        border: 1px solid var(--border);
        z-index: 2;
        animation: modalFade 0.3s ease;
    }

    @keyframes modalFade {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .talk-modal-body h2 {
        font-family: var(--font-main);
        font-size: 28px;
        margin-bottom: 10px;
    }

    .talk-modal-body p {
        font-family: var(--font-text);
        margin-bottom: 30px;
        opacity: 0.85;
    }

    .talk-modal-body h2, .talk-modal-body p {
        color: var(--text);
    }

    /* FORM */
    .talk-form {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    textarea {
        resize: none;
        overflow: hidden;
    }

    .talk-form input,
    .talk-form textarea {
        padding: 14px 18px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-text);
    }

    .talk-submit-btn {
        background: var(--primary);
        color: #ffffff;
        padding: 12px 26px;
        border-radius: 999px;
        font-size: 14px;
        font-weight: 600;
        border: none;
        cursor: pointer;
        align-self: flex-start;
        transition: 0.3s ease;
    }

    .talk-submit-btn:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }

    .toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        background: var(--bg);
        color: var(--text);
        padding: 14px 20px;
        border-radius: 10px;
        border: 1px solid var(--border);
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        font-family: var(--font-text);
        font-size: 14px;
        opacity: 0;
        transform: translateY(20px);
        pointer-events: none;
        transition: 0.3s ease;
        z-index: 999999;
    }

    .toast.show {
        opacity: 1;
        transform: translateY(0);
    }

    /* MOBILE */
    @media (max-width: 768px) {
        .talk-modal-content {
            margin: 40px auto;
            padding: 25px;
        }
    }

    /* Mobile Styles */
    @media (max-width: 1024px) {
        .header-inner {
            padding: 0 16px;
        }

        .nav-list {
            position: fixed;
            top: 80px;
            left: 0;
            right: 0;
            width: 100%;
            flex-direction: column;
            background: var(--bg);
            padding: 30px 20px;
            gap: 20px;
            border-top: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            transform: translateY(-150%);
            transition: transform 0.3s ease;
            z-index: 9998;
            align-items: center;
        }

        .nav-list.active {
            transform: translateY(0);
        }

        .nav-list li {
            width: 100%;
            text-align: center;
        }

        .nav-list a {
            display: block;
            padding: 15px;
        }

        /* Show mobile CTA in dropdown */
        .mobile-cta-item {
            display: block;
            margin-top: 10px;
        }

        .mobile-cta {
            display: inline-block;
            padding: 12px 30px;
            font-size: 14px;
        }

        /* Hide desktop CTA */
        .desktop-cta {
            display: none;
        }

        .mobile-toggle {
            display: block;
        }

        /* Adjust theme toggle for mobile if needed */
        :global(.theme-toggle) {
            order: -1;
        }
    }

    @media (max-width: 480px) {
        .brand-name {
            font-size: 12px;
        }

        .brand img {
            height: 36px;
        }
    }
</style>

<script>
    // Mobile navigation functionality
    document.addEventListener('DOMContentLoaded', function() {
        const mobileToggle = document.getElementById("mobileToggle");
        const navList = document.getElementById("navList");

        if (!mobileToggle || !navList) {
            console.error('Mobile nav elements not found');
            return;
        }

        let isMenuOpen = false;

        const toggleMenu = function() {
            isMenuOpen = !isMenuOpen;
            navList.classList.toggle("active", isMenuOpen);
            mobileToggle.setAttribute("aria-expanded", String(isMenuOpen));
            mobileToggle.textContent = isMenuOpen ? "✕" : "☰";
            document.body.style.overflow = isMenuOpen ? 'hidden' : '';
        };

        mobileToggle.addEventListener("click", function(e) {
            e.preventDefault();
            e.stopPropagation();
            toggleMenu();
        });

        // Close menu when clicking a link
        const navLinks = navList.querySelectorAll('a');
        navLinks.forEach(function(link) {
            link.addEventListener('click', function() {
                if (window.innerWidth <= 1024 && isMenuOpen) {
                    toggleMenu();
                }
            });
        });

        // Close on outside click
        document.addEventListener('click', function(e) {
            const target = e.target as Node;

            if (!(target instanceof Node)) return;

            if (window.innerWidth <= 1024 && 
                isMenuOpen &&
                !navList.contains(target!) && 
                !mobileToggle.contains(target)) {
                toggleMenu();
            }
        });

        // Handle escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && isMenuOpen) {
                toggleMenu();
            }
        });

        // Active section highlighting for anchor links
        const updateActiveLink = function() {
            const sections = document.querySelectorAll('section[id]');
            const scrollPos = window.scrollY + 100;

            sections.forEach(function(section) {
                const sectionEl = section as HTMLElement;
                const top = sectionEl.offsetTop;
                const height = sectionEl.offsetHeight;
                const id = section.getAttribute('id');

                if (scrollPos >= top && scrollPos < top + height) {
                    navLinks.forEach(function(link) {
                        link.classList.remove('active');
                        if (link.getAttribute('href') === '#' + id) {
                            link.classList.add('active');
                        }
                    });
                }
            });
        };

        window.addEventListener('scroll', updateActiveLink, { passive: true });
        updateActiveLink();
    });

    // Talk modal functionality
    document.addEventListener('DOMContentLoaded', function() {
        const openTalk = document.getElementById("openTalk");
        const openTalkMobile = document.getElementById("openTalkMobile");
        const talkModal = document.getElementById("talkModal");
        const closeTalk = document.getElementById("closeTalk");

        if (!talkModal || !closeTalk) {
            console.error('Talk modal elements not found');
            return;
        }

        const overlay = talkModal.querySelector(".talk-modal-overlay");

        const openModal = function(e) {
            if (e) e.preventDefault();
            talkModal.classList.add("active");
            document.body.style.overflow = "hidden";
        };

        const closeModal = function() {
            talkModal.classList.remove("active");
            document.body.style.overflow = "";
        };

        if (openTalk) {
            openTalk.addEventListener("click", openModal);
        }
        
        if (openTalkMobile) {
            openTalkMobile.addEventListener("click", openModal);
        }
        
        closeTalk.addEventListener("click", closeModal);
        
        if (overlay) {
            overlay.addEventListener("click", closeModal);
        }

        document.addEventListener("keydown", function(e) {
            if (e.key === "Escape") closeModal();
        });
    });

    // Form functionality
    document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById("talkForm") as HTMLFormElement;
        const talkModal = document.getElementById("talkModal");
        const toast = document.getElementById("toast");

        if (!form || !toast) {
            console.error('Form elements not found');
            return;
        }

        function showToast(message, success) {
            toast.textContent = message;
            toast.style.borderColor = success ? "#22c55e" : "#ef4444";
            toast.classList.add("show");

            setTimeout(function() {
                toast.classList.remove("show");
            }, 3000);
        }

        form.addEventListener("submit", async function(e) {
            e.preventDefault();

            const submitBtn = form.querySelector(".talk-submit-btn") as HTMLButtonElement;
            if (!submitBtn) return;

            submitBtn.disabled = true;
            submitBtn.textContent = "Sending...";

            const data = Object.fromEntries(new FormData(form as HTMLFormElement));

            try {
                const res = await fetch("./api/contact", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify(data)
                });

                if (res.ok) {
                    submitBtn.textContent = "Sent ✓";

                    setTimeout(function() {
                        if (talkModal) {
                            talkModal.classList.remove("active");
                            document.body.style.overflow = "";
                        }
                        showToast("Message sent successfully!", true);
                        form.reset();
                        submitBtn.textContent = "Submit";
                        submitBtn.disabled = false;
                    }, 800);
                } else {
                    submitBtn.textContent = "Submit";
                    submitBtn.disabled = false;
                    showToast("Failed to send message.", false);
                }
            } catch (err) {
                submitBtn.textContent = "Submit";
                submitBtn.disabled = false;
                showToast("Something went wrong.", false);
            }
        });
    });
</script>