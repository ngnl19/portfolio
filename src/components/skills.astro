---
interface Skill {
  name: string;
  level: number;
}

interface Props {
  title?: string;
  subtitle?: string;
  skills?: Skill[];
}

const {
  title = "My Skills",
  subtitle = "Technologies and tools I work with.",
  skills = [
    { name: "HTML / CSS", level: 5 },
    { name: "JavaScript", level: 4 },
    { name: "Astro", level: 4 },
    { name: "React", level: 3 },
    { name: "UI/UX Design", level: 4 },
  ]
} = Astro.props;
---

<section class="skills" id="skills">
  <div class="container skills-grid">

    <!-- LEFT -->
    <div class="skills-content">
      <h2 class="skills-title">{title}</h2>
      <p class="skills-subtitle">{subtitle}</p>

      <div class="skills-card">
        {skills.map(skill => (
          <div class="skill-row">
            <span class="skill-name">{skill.name}</span>

            <div class="stars">
              {[...Array(5)].map((_, i) => (
                <span class={i < skill.level ? "star filled" : "star"}>★</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- RIGHT -->
    <div class="skills-visual">

      <div class="card-stack">

  <!-- CARD 3 -->
  <div class="stack-card card-3 card-item">
    <div
      class="card-bg-layer"
      style="background-image:url('https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=800&auto=format&fit=crop')">
    </div>

    <div class="card-content-wrapper">
      <div class="card-head">
        PROGRAM <br/> DETAILS
      </div>

      <div class="card-body-text">
        This remote internship program is open to volunteers and school-mandated applicants who must render at least 3 months.
      </div>

      <div class="card-num">03</div>
    </div>
  </div>


  <!-- CARD 2 -->
  <div class="stack-card card-2 card-item">
    <div
      class="card-bg-layer"
      style="background-image:url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=800&auto=format&fit=crop')">
    </div>

    <div class="card-content-wrapper">
      <div class="card-head">
        CAREER <br/> READY
      </div>

      <div class="card-body-text">
        As a tight-knit company, we provide meaningful experience and a friendly working environment.
      </div>

      <div class="card-num">02</div>
    </div>
  </div>


  <!-- CARD 1 -->
    <div class="stack-card card-1 card-item">
        <div
        class="card-bg-layer"
        style="background-image:url('https://images.unsplash.com/photo-1600880292203-757bb62b4baf?q=80&w=800&auto=format&fit=crop')">
        </div>

        <div class="card-content-wrapper">
        <div class="card-head">
            TAILOR-FIT <br/> EXPERIENCE
        </div>

        <div class="card-body-text">
            Tasks are tailored based on the work experience you're looking for.
        </div>

        <div class="card-num">01</div>
        </div>
    </div>

    </div>

      <p class="hover-text">Hover stack to reveal details</p>

    </div>

  </div>
</section>

<style>
.skills{
  margin-top: 0;
  padding:100px 0;
  background:var(--bg);
}

/* GRID */

.skills-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:60px;
  align-items:center;
}

/* LEFT SIDE */

.skills-title{
  font-family:var(--font-main);
  font-size:2.5rem;
  color:var(--primary);
}

.skills-subtitle{
  font-family:var(--font-text);
  color: var(--text);
  margin-top:10px;
  margin-bottom:25px;
  opacity:.8;
}

/* SKILL CARD */

.skills-card{
  border:1px solid var(--border);
  border-radius:20px;
  padding:30px;
  display:flex;
  flex-direction:column;
  gap:18px;
  background:var(--bg);
}

/* SKILL ROW */

.skill-row{
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.skill-name{
  font-family:var(--font-main);
  font-size:1rem;
  font-weight:500;
  color: var(--text);
}

.stars{
  display:flex;
  gap:4px;
}

.star{
  font-size:1rem;
  color:#ccc;
}

.star.filled{
  color:var(--primary);
}

/* RIGHT SIDE */

.skills-visual{
  display:flex;
  flex-direction:column;
  align-items:center;
}

/* CARD STACK */

.card-stack{
  position:relative;
  width:260px;
  height:340px;
  perspective:1000px;
  cursor: pointer;
}

/* STACK CARD BASE */

.stack-card{
  position:absolute;
  width:100%;
  height:100%;
  border-radius:20px;
  display:flex;
  align-items:end;
  justify-content:end;
  padding:20px;
  font-size:2rem;
  font-weight:bold;
  color:white;
  font-family: var(--font-main);
  top:0;
  left:0;

  transition:all .5s cubic-bezier(.25,.8,.25,1);
  box-shadow:0 20px 40px rgba(0,0,0,.25);
}

.card-bg-layer{
  position:absolute;
  inset:0;
  background-size:cover;
  background-position:center;
  border-radius:20px;
  z-index:1;
}

/* dark overlay for readability */
.card-bg-layer::after{
  content:"";
  position:absolute;
  inset:0;
  background:linear-gradient(
    to top,
    rgba(0,0,0,.7),
    rgba(0,0,0,.2)
  );
  border-radius:20px;
}

.card-content-wrapper{
  position:relative;
  z-index:2;
  display:flex;
  flex-direction:column;
  height:100%;
}

.card-head{
  font-size:1.2rem;
  font-weight:700;
  letter-spacing:.5px;
}

.card-body-text{
  font-family:var(--font-text);
  font-size:.85rem;
  margin-top:10px;
  line-height:1.4;
  opacity:.9;
}

.card-num{
  margin-top:auto;
  font-size:2rem;
  font-weight:700;
}

/* CARD COLORS + STACK POSITION */

.card-1{
  background:#444;
  transform:rotate(-4deg) translateY(0);
  z-index:3;
}

.card-2{
  background:#d97706;
  transform:rotate(4deg) translateY(12px);
  z-index:2;
}

.card-3{
  background:#7f1d1d;
  transform:rotate(10deg) translateY(24px);
  z-index:1;
}

/* HOVER FAN EFFECT */

.card-stack .card-1{
  transform:rotate(-15deg) translateX(-60px) translateY(-10px);
}

.card-stack .card-2{
  transform:rotate(0deg) translateY(10px);
}

.card-stack .card-3{
  transform:rotate(15deg) translateX(60px) translateY(-10px);
}

.card-stack .card-1:hover {
    transform: rotate(-15deg) translateX(-60px) translateY(-100px);
}

.card-stack .card-2:hover {
    transform: translateY(-100px);
}

.card-stack .card-3:hover {
    transform: rotate(15deg) translateX(60px) translateY(-100px);
}

/* HOVER TEXT */

.hover-text{
  margin-top:70px;
  font-size:.9rem;
  opacity:.7;
  font-family:var(--font-text);
  color: var(--text);
}

/* RESPONSIVE */

@media(max-width:900px){

.skills-grid{
  grid-template-columns:1fr;
}

.skills-visual{
  order:-1;
}



}
</style>