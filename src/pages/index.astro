---
import BaseLayout from "../layouts/baseLayout.astro";
import Hero from "../components/hero.astro";
import About from "../components/about.astro";

const titles = ["Mark Andrew", "a Developer", "a Freelancer", "a Tutor", "a Virtual Assistant"];
---

<BaseLayout>
  <Hero
    titles={titles}
    tagline="“There is nothing so useless as doing efficiently that which should not be done at all.” -Peter Drucker"
    align="start"
    tags={["Developer", "Freelancer", "Tutor", "Virtual Assistant"]}
  />
  
  <About 
    imageSrc="/assets/about.jpg"
  />
</BaseLayout>