---
import BaseLayout from "../layouts/baseLayout.astro";
import Hero from "../components/hero.astro";
import About from "../components/about.astro";
import Skills from "../components/skills.astro";

const titles = ["Mark Andrew", "a Developer", "a Freelancer", "a Tutor", "a Virtual Assistant"];
---

<BaseLayout>
  <Hero
    titles={titles}
    tagline="If you're doing something, do it at 100% or don't do it at all."
    align="start"
    tags={["Developer", "Freelancer", "Tutor", "Virtual Assistant"]}
  />
  <About />
  <Skills />
</BaseLayout>